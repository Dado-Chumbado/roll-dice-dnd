discord_token=<your_discord_token>
db=stats
user=postgres
pass=
host=127.0.0.1
port=5432

command_char=!

# Discord command name overrides — pattern: DISCORD_CMD_{CATEGORY}_{COMMAND}
# Leave empty to use the defaults from config.json. Examples:
# DISCORD_CMD_ROLL_ADVANTAGE=v
# DISCORD_CMD_ROLL_DISADVANTAGE=d
# DISCORD_CMD_ROLL_ROLL_DICE=r
# DISCORD_CMD_INITIATIVE_ROLL_INITIATIVE=i

save_stats_db=1 # Or empty to disable

limit_of_dice_per_roll=40
limit_of_die_size=1000

sentry_dsn=
traces_sample_rate=1.0

telegram_token=<your_telegram_bot_token>
telegram_allowed_chats=   # Comma-separated chat IDs. Empty = allow all.

# Telegram command names (defaults shown). Supports comma-separated aliases e.g. "adv,v"
TELEGRAM_CMD_ROLL=roll    # also always registers /r
TELEGRAM_CMD_ADV=adv
TELEGRAM_CMD_DIS=dis

# D20 IRL physical dice integration (https://github.com/rsandrini/D20-IRL-detection)
# Set D20_IRL_ENABLED=true to activate. All other D20_IRL_* vars are ignored when disabled.
D20_IRL_ENABLED=true
D20_IRL_URL=http://<pi-ip>:5000   # Base URL of the Raspberry Pi API
D20_IRL_COMMAND=irl               # Telegram command name (default: irl)
D20_IRL_USERNAME=rsandrini        # Username for authenticated endpoint /u/<username>/roll (required)
D20_IRL_TOKEN=b8ddbc30-ca78-4d7f-9f7c-be07368e97ce       # Bearer token for the authenticated endpoint (required)